{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "resourceGroupName": {
        "value": "${AZURE_RESOURCE_GROUP}"
      },
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "aksClusterName": {
        "value": "${AKS_CLUSTER_NAME}"
      },
      "aksNodeResourceGroupName": {
        "value": "${AKS_NODE_RESOURCE_GROUP_NAME}"
      },
      "aksSshPublicKey": {
        "value": "${AKS_SSH_PUBLIC_KEY}"
      },
      "containerRegistryName": {
        "value": "${CONTAINER_REGISTRY_NAME}"
      },
      "logAnalyticsWorkspaceName": {
        "value": "${LOG_ANALYTICS_WORKSPACE_NAME}"
      },
      "applicationInsightsName": {
        "value": "${APPLICATION_INSIGHTS_NAME}"
      },
      "apiIdentityName": {
        "value": "${API_IDENTITY_NAME}"
      }
    }
}
